{
  "name": "visaradar24",
  "compatibility_date": "2026-03-13",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "main": "api/worker.js",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "visaradar24-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "e19a406a1da04103a245e6c253e7c58a",
      "preview_id": "e19a406a1da04103a245e6c253e7c58a"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "SITE_URL": "https://visaradar24.com"
  }
}
